{
  "extends": "@create-figma-plugin/tsconfig",
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2021", "DOM"],
    "baseUrl": ".",
    "paths": {
      "react": ["./node_modules/preact/compat"],
      "react-dom": ["./node_modules/preact/compat"]
    },
    "strict": true,
    "skipLibCheck": true,
    "typeRoots": ["node_modules/@figma", "node_modules/@types"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "*.ts", "*.js", "*.cjs"]
}
